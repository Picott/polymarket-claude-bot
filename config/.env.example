# ─────────────────────────────────────────────────────────────────
#  polymarket-claude-bot — configuración
#  Copia este archivo: copy config\.env.example config\.env
#  NUNCA subas config\.env a git (ya está en .gitignore)
# ─────────────────────────────────────────────────────────────────

# ── Claude / Anthropic ───────────────────────────────────────────
# Obtén tu key en: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ── Polymarket ───────────────────────────────────────────────────
# Clave privada de tu wallet (formato hex, sin 0x)
# Solo necesaria para modo LIVE — en paper mode no se usa
POLYMARKET_PRIVATE_KEY=

# ── Modo de operación ────────────────────────────────────────────
# paper  → simula trades, no mueve dinero real
# live   → ejecuta trades reales (requiere POLYMARKET_PRIVATE_KEY)
TRADE_MODE=paper

# ── Parámetros del bot ───────────────────────────────────────────
# Tamaño máximo por posición en USDC
MAX_POSITION_USDC=10

# Edge mínimo para ejecutar un trade (0.10 = 10%)
MIN_EDGE=0.10

# Confianza mínima del modelo para ejecutar (0.80 = 80%)
MIN_CONFIDENCE=0.80

# Pérdida diaria máxima en USDC antes de pausar el bot
DAILY_LOSS_LIMIT_USDC=50

# Número máximo de posiciones abiertas simultáneas
MAX_OPEN_POSITIONS=5

# ── Dashboard ────────────────────────────────────────────────────
# Puerto del servidor del dashboard (default: 5000)
DASHBOARD_PORT=5000
